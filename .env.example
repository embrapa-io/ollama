# Portas no host (Ollama passa pelo nginx; SGLang é mapeado direto)
PORT_OLLAMA=11434
PORT_SGLANG=11435

LLM_PATH=/mnt/llm

# =============================================================================
# Ollama (CPU-only) — embeddings via AVX-512
# =============================================================================
# As GPUs ficam dedicadas ao SGLang. O Ollama roda em CPU apenas para servir
# modelos de embedding (bge-m3, nomic-embed-text, mxbai-embed-large, etc.).
# Aproveita os 72 threads do dual Xeon Gold 6254.

# Context window size (default: 2048)
OLLAMA_CONTEXT_LENGTH=16384

# Flash Attention - faster inference, lower VRAM usage
OLLAMA_FLASH_ATTENTION=1

# New inference engine (improved performance)
OLLAMA_NEW_ENGINE=1

# Concurrent Requests (em CPU, com 72 threads disponíveis)
OLLAMA_NUM_PARALLEL=8

# Máximo de modelos simultâneos em memória (256 GB RAM)
OLLAMA_MAX_LOADED_MODELS=4

# Keep models loaded (reduces cold start latency)
# Use 24h for production, -1 for indefinite
OLLAMA_KEEP_ALIVE=24h

# Threads OpenMP por instância (AVX-512). 36 cores físicos ÷ 4 modelos = 9
# (estrito em cores físicos); 16 dá margem para picos sem oversubscribir os
# 72 threads lógicos. Ajustar conforme perfil de carga.
OMP_NUM_THREADS=16

# Afinidade NUMA — evita thrashing entre os dois sockets Xeon Gold 6254.
OMP_PROC_BIND=close
OMP_PLACES=cores

# =============================================================================
# SGLang — Qwen2.5-VL-32B-Instruct-AWQ (dense + vision) em dual GPU (TP=2)
# =============================================================================
# Qwen2.5-VL-32B é dense (~19 GB AWQ) com visual encoder maduro (qwen2_vl.py),
# compatível com Turing/sm_75 onde Qwen3.x-VL quebra. Útil para leitura de
# screenshots (Chrome DevTools, UIs) + texto. Tool calling via parser 'qwen'.

# Token do HuggingFace Hub — recomendado para evitar rate-limiting no download
# e obrigatório para modelos gated. Obter em https://huggingface.co/settings/tokens
# (escopo "Read" é suficiente). Usado pelo ./download-model.sh.
#HF_TOKEN=

# Diretório no host onde o modelo foi baixado (use ./download-model.sh).
SGLANG_MODEL_PATH=/data/sglang/models/qwen2.5-vl-32b-instruct-awq

# Repositório HuggingFace do modelo (usado apenas pelo download-model.sh).
SGLANG_MODEL_REPO=Qwen/Qwen2.5-VL-32B-Instruct-AWQ

# Nome exposto na API (campo "model" nas requisições)
SGLANG_SERVED_MODEL_NAME=qwen2.5-vl-32b-instruct-awq

# Tensor Parallelism — 2 GPUs (Quadro RTX 6000)
SGLANG_TP_SIZE=2

# Contexto em tokens. Nativo 32K; 64K é o sweet spot em 2×24 GB (cabe com
# folga pra 6 slots concorrentes e screenshots). Para 128K via YaRN, adicione
# em SGLANG_EXTRA_ARGS:
#   --json-model-override-args '{"rope_scaling":{"type":"yarn","factor":4.0,"original_max_position_embeddings":32768}}'
# E reduza SGLANG_MAX_RUNNING_REQUESTS para 2 ou ative CPU offload.
SGLANG_CONTEXT_LENGTH=65536

# Requisições concorrentes (baseado em KV cache disponível).
SGLANG_MAX_RUNNING_REQUESTS=6

# Fração estática da VRAM reservada (default SGLang: 0.88).
# Quadro RTX 6000 Turing tolera 0.90; reduzir para 0.85 se der OOM.
SGLANG_MEM_FRACTION=0.90

# CPU offload em GB por GPU (requer RAM). Para modelos dense que cabem em VRAM
# deixar em 0. Útil apenas para casos MoE/AWQ em Turing — ver README.
SGLANG_CPU_OFFLOAD_GB=0

# GPUs visíveis para o SGLang (vazio = todas)
SGLANG_NVIDIA_VISIBLE_DEVICES=all

# Parsers (por família de modelo).
# reasoning-parser: deepseek-r1, deepseek-v3, glm45, gpt-oss, kimi, kimi_k2,
#   mimo, qwen3, qwen3-thinking, minimax, minimax-append-think, step3, step3p5,
#   mistral, nemotron_3, interns1
# tool-call-parser: deepseekv3, deepseekv31, deepseekv32, glm, glm45, glm47,
#   gpt-oss, kimi_k2, lfm2, llama3, mimo, mistral, pythonic, qwen, qwen25,
#   qwen3_coder, step3, step3p5, minimax-m2, trinity, interns1, hermes,
#   gigachat3
# Para Qwen3.5 dense → reasoning 'qwen3', tool-call 'qwen' (qwen25 é alias
# deprecado, SGLang orienta usar 'qwen'). Para Qwen3 Coder → 'qwen3_coder'.
SGLANG_REASONING_PARSER=qwen3
SGLANG_TOOL_CALL_PARSER=qwen

# Flags extras do SGLang — acrescentados no fim do comando.
# Em Turing/sm_75: --disable-cuda-graph, triton/pytorch backends (flashinfer
#   CUTLASS DSL não compila).
# Para modelos VL: acrescentar --enable-multimodal.
# Em GPUs sm_80+ (Ampere+) remover os flags de Turing recupera performance.
SGLANG_EXTRA_ARGS=--disable-cuda-graph --attention-backend triton --sampling-backend pytorch --enable-multimodal
